              "\n",
              "     <input type=\"file\" id=\"files-9fcc8da2-41dc-40c0-b3ac-eb38c7a49cb5\" name=\"files[]\" multiple disabled\n",
              "        style=\"border:none\" />\n",
              "     <output id=\"result-9fcc8da2-41dc-40c0-b3ac-eb38c7a49cb5\">\n",
              "      Upload widget is only available when the cell has been executed in the\n",
              "      current browser session. Please rerun this cell to enable.\n",
              "      </output>\n",
              "      <script>// Copyright 2017 Google LLC\n",
